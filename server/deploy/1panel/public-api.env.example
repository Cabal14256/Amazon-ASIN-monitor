# 基于 server/.env.example 的公网 API 覆盖项
# 用途：对外提供 /api、/ws 与 analytics 查询

NODE_ENV=production
LOG_LEVEL=INFO

PROCESS_ROLE=api
SCHEDULER_ENABLED=false

# 如果实例共享同一宿主机网络命名空间，请确保和其它 API 角色端口不同
PORT=3001
TRUST_PROXY=1

# 按实际前端域名修改
CORS_ORIGIN=https://app.example.com
# 仅脚本/调试使用
API_BASE_URL=https://api.example.com

API_RATE_LIMIT_ENABLED=true

ANALYTICS_AGG_ENABLED=1
ANALYTICS_AGG_CRON_EXPRESSION=5 * * * *
ANALYTICS_AGG_REFRESH_HOURS_WINDOW=72
ANALYTICS_AGG_REFRESH_DAYS_WINDOW=35
ANALYTICS_QUERY_TIMEOUT_MS=90000
ANALYTICS_PERIOD_SUMMARY_QUERY_TIMEOUT_MS=240000
