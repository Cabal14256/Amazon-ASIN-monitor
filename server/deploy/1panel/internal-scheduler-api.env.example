# 基于 server/.env.example 的内网 scheduler/API 覆盖项
# 用途：只承担 scheduler 与内部诊断，不接公网流量

NODE_ENV=production
LOG_LEVEL=INFO

PROCESS_ROLE=api
SCHEDULER_ENABLED=true

# 如果实例共享同一宿主机网络命名空间，请确保和公网 API 端口不同
PORT=3002
TRUST_PROXY=1

# 如非必须，不要为该实例暴露公网域名
CORS_ORIGIN=https://app.example.com
API_BASE_URL=http://127.0.0.1:3002

API_RATE_LIMIT_ENABLED=false

ANALYTICS_AGG_ENABLED=1
ANALYTICS_AGG_CRON_EXPRESSION=5 * * * *
ANALYTICS_AGG_REFRESH_HOURS_WINDOW=72
ANALYTICS_AGG_REFRESH_DAYS_WINDOW=35
ANALYTICS_QUERY_TIMEOUT_MS=90000
ANALYTICS_PERIOD_SUMMARY_QUERY_TIMEOUT_MS=240000
